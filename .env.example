# ============================================
# LLM Provider — pick ONE backend below
# ============================================
#
# Run with: python main.py --mode local <url>
#
# --- Option 1: OpenAI-compatible gateway (recommended) ---
# Works with 9-router, LiteLLM, Ollama, vLLM, etc.
# Supports routing to OpenAI, Anthropic, Google, Groq, Mistral, etc.
# OPENAI_API_KEY=sk-your_api_key_here
# OPENAI_BASE_URL=http://localhost:20128/v1
# OPENAI_MODEL=gpt-4o-mini
#
# --- Option 2: OpenAI official ---
# OPENAI_API_KEY=sk-your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini
#
# --- Option 3: Anthropic Claude (via 9-router/gateway) ---
# Use 9-router or LiteLLM as an OpenAI-compatible proxy for Claude.
# OPENAI_API_KEY=sk-your_9router_key_here
# OPENAI_BASE_URL=http://localhost:20128/v1
# OPENAI_MODEL=claude-sonnet-4-20250514
#
# --- Option 4: Google Gemini (via 9-router/gateway) ---
# OPENAI_API_KEY=sk-your_9router_key_here
# OPENAI_BASE_URL=http://localhost:20128/v1
# OPENAI_MODEL=gemini-2.5-flash
#
# --- Option 5: MuAPI cloud (legacy) ---
# Run without --mode local flag.
# MUAPI_API_KEY=your_muapi_key_here

# ============================================
# Whisper (local mode)
# ============================================
LOCAL_WHISPER_MODEL=base
LOCAL_WHISPER_DEVICE=auto
LOCAL_OUTPUT_DIR=output

# ============================================
# Subtitles (local mode)
# ============================================
SUBTITLES_ENABLED=true
SUBTITLE_FONT=Arial Black
SUBTITLE_FONT_SIZE_RATIO=0.055
SUBTITLE_PRIMARY_COLOR=&H00FFFFFF
SUBTITLE_HIGHLIGHT_COLOR=&H0000FFFF
SUBTITLE_OUTLINE_COLOR=&H00000000
SUBTITLE_OUTLINE_WIDTH=3
SUBTITLE_MARGIN_V_RATIO=0.12
SUBTITLE_WORDS_PER_CHUNK=3
SUBTITLE_MAX_CHUNK_SECONDS=1.4
SUBTITLE_UPPERCASE=true
SUBTITLE_BOLD=true
