# API mode (default)
MUAPI_API_KEY=your_muapi_key_here

# Local mode (--mode local) — only the OPENAI key is required
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini
LOCAL_WHISPER_MODEL=base
LOCAL_WHISPER_DEVICE=auto
LOCAL_OUTPUT_DIR=output

# Subtitles (local mode only) — word-level karaoke captions burned into each short.
SUBTITLES_ENABLED=true
SUBTITLE_FONT=Arial Black
SUBTITLE_FONT_SIZE_RATIO=0.055
SUBTITLE_PRIMARY_COLOR=&H00FFFFFF
SUBTITLE_HIGHLIGHT_COLOR=&H0000FFFF
SUBTITLE_OUTLINE_COLOR=&H00000000
SUBTITLE_OUTLINE_WIDTH=3
SUBTITLE_MARGIN_V_RATIO=0.12
SUBTITLE_WORDS_PER_CHUNK=3
SUBTITLE_MAX_CHUNK_SECONDS=1.4
SUBTITLE_UPPERCASE=true
SUBTITLE_BOLD=true
